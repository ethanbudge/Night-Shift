# Night Shift configuration. Sourced by night-shift.sh; numeric knobs are also
# read by check_budget.py via the environment.

# --- Paths & identity ---------------------------------------------------------
CLAUDE_BIN="$HOME/.local/bin/claude"          # `which claude` after installing the CLI
REPO_DIR="$HOME/claude-night-shift/tasks-repo"
GITHUB_REPO="YOURNAME/claude-tasks"           # owner/repo slug -- EDIT ME
LOG_DIR="$HOME/claude-night-shift/logs"
SECRETS_DIR="$HOME/claude-night-shift/secrets"
MODE_FILE="$HOME/claude-night-shift/mode"     # schedule override; manage with mode.sh (`nightshift`)

# --- Working hours (local time; weekday 0=Mon ... 6=Sun) -----------------------
WORK_START_HOUR=8
WORK_END_HOUR=18
WORKDAYS=0,1,2,3,4

# --- Weekly budget model --------------------------------------------------------
# Percentage points of the WEEKLY limit you consume per hour of normal workday
# usage. Start at 1.0 and calibrate from logs/usage-log.csv after a week
# (see DESIGN.md). Lower = more overnight budget freed up.
PCT_PER_WORK_HOUR=1.0
SAFETY_FACTOR=1.25          # multiplier on the reserve, headroom for heavy days
MIN_SURPLUS_START=8         # points of surplus required to start a run
MIN_SURPLUS_CONTINUE=3      # points required to start each additional task
WEEKLY_HARD_CAP=85          # never run at/above this weekly utilization, period
FIVE_HOUR_MAX_START=90      # don't start a run this deep into a session window
FIVE_HOUR_MAX_CONTINUE=95   # don't start another task this deep

# --- Per-run limits -------------------------------------------------------------
MAX_TASKS_PER_RUN=6         # task invocations per hourly wake-up
TASK_TIMEOUT_MIN=90         # hard wall-clock cap per task invocation
MAX_TURNS_PER_TASK=250      # claude --max-turns cap
