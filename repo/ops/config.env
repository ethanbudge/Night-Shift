# Night Shift configuration. Sourced by night-shift.sh/night-shift.ps1;
# numeric knobs are also read by check_budget.py via the environment.

# --- Paths & identity ---------------------------------------------------------
CLAUDE_BIN="$HOME/.local/bin/claude"          # `which claude` after installing the CLI.
                                               # If you installed some other way, `command -v claude`
                                               # (or, on Windows, `claude` if it's on PATH) is the
                                               # general fallback -- edit this line to match.
REPO_DIR="$HOME/claude-night-shift/tasks-repo"
GITHUB_REPO="YOURNAME/claude-tasks"           # owner/repo slug -- EDIT ME
LOG_DIR="$HOME/claude-night-shift/logs"
SECRETS_DIR="$HOME/claude-night-shift/secrets"
MODE_FILE="$HOME/claude-night-shift/mode"     # schedule override; manage with mode.sh (`nightshift`)

# --- Working hours (local time; weekday 0=Mon ... 6=Sun) -----------------------
WORK_START_HOUR=8
WORK_END_HOUR=18
WORKDAYS=0,1,2,3,4

# --- Weekly budget model --------------------------------------------------------
# Percentage points of the WEEKLY limit you consume per hour of normal workday
# usage. Start at 1.0 and calibrate from logs/usage-log.csv after a week
# (see DESIGN.md). Lower = more overnight budget freed up.
PCT_PER_WORK_HOUR=1.0
SAFETY_FACTOR=1.25          # multiplier on the reserve, headroom for heavy days
MIN_SURPLUS_START=8         # points of surplus required to start a run
MIN_SURPLUS_CONTINUE=3      # points required to start each additional task
WEEKLY_HARD_CAP=85          # never run at/above this weekly utilization, period
FIVE_HOUR_MAX_START=90      # don't start a run this deep into a session window
FIVE_HOUR_MAX_CONTINUE=95   # don't start another task this deep

# --- Per-run limits -------------------------------------------------------------
MAX_TASKS_PER_RUN=6         # task invocations per hourly wake-up (review passes,
                             # if REVIEW_MODE is on, share this same cap)
TASK_TIMEOUT_MIN=90         # hard wall-clock cap per task invocation
MAX_TURNS_PER_TASK=250      # claude --max-turns cap
MODEL=""                    # BASELINE model -- e.g. "claude-sonnet-5" or "claude-opus-4-8"; empty =
                             # account default. This is what starts every run and what a task falls
                             # back to if it has no model:<tag> label, or one that isn't a key in
                             # MODEL_ALLOWLIST below. Opus is available on Pro (as of May 2026) but
                             # burns weekly budget much faster than Sonnet -- consider the effect on
                             # PCT_PER_WORK_HOUR calibration before making it the baseline.
                             # A non-empty 'model:' line in CONTROL.md (if your hub repo has one)
                             # overrides this (and any per-task tag below) for a given run without
                             # editing this file -- see CONTROL.md's own comments. Manage this knob
                             # day-to-day with `nightshift model <id>|default` instead of hand-editing it.

# --- Per-task model tags ---------------------------------------------------------
# Maps an issue's `model:<tag>` label (see CLAUDE.md's Labels table) to the actual
# model ID passed to `claude --model`. An issue with no model:<tag> label, or a
# tag that isn't a key here, runs under MODEL (the baseline) instead -- never fails
# the task over a bad or unrecognized tag. Precedence, highest first:
#   CONTROL.md's `model:` line  >  the picked issue's model:<tag> label  >  MODEL above  >  account default
# Keep this in sync with the `model:*` labels that actually exist on the hub repo
# (created by ops/setup-labels.sh, or by `nightshift update-models` -- see mode.sh).
MODEL_ALLOWLIST="sonnet=claude-sonnet-5,opus=claude-opus-4-8,haiku=claude-haiku-4-5-20251001,fable=claude-fable-5"

# --- Review pass ------------------------------------------------------------
# When "on", once the normal task queue comes back genuinely empty for a run
# (not just out of budget/time), night-shift.sh gives the highest-priority
# completed-and-unreviewed issue one more pass from a stronger model before
# the run ends -- sonnet (or account default) -> opus -> fable, fixed, not
# configurable per-issue. Off by default: it spends idle end-of-queue credits
# on a second opinion, which is a deliberate tradeoff, not a free lunch.
# Manage day-to-day with `nightshift review on|off|status` instead of
# hand-editing this. See DESIGN.md's "Review System" roadmap entry.
REVIEW_MODE="off"
